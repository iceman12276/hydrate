# Canonical PUBLIC env var names. Safe to ship in client bundles.
# Copy to .env.local (web) / .env (mobile) and fill from the Supabase plugin:
#   get_project_url       -> *_SUPABASE_URL
#   get_publishable_keys  -> *_SUPABASE_ANON_KEY (publishable/anon, NOT service-role)

# Web + Desktop (Next.js)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mobile (Expo)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# NEVER put the service-role key here or in any client env. Server-only.
